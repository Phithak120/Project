generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



enum OrderStatus {
  PENDING
  ACCEPTED
  PICKED_UP
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  Unpaid
  Paid
}

model Customer {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  name             String?
  password         String?
  googleId         String?  @unique
  facebookId       String?  @unique
  lineId           String?  @unique
  phone            String?  @unique
  fcmToken         String?
  
  isVerified       Boolean   @default(false)
  otpCode          String?
  otpExpires       DateTime?
  isActive         Boolean   @default(true)
  balance          Decimal   @default(0)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  orders           Order[]   @relation("CustomerOrders")
}

model Merchant {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  name             String?
  password         String?
  googleId         String?  @unique
  facebookId       String?  @unique
  lineId           String?  @unique
  phone            String?  @unique
  fcmToken         String?
  
  storeName        String?  
  storeAddress     String?  

  isVerified       Boolean   @default(false)
  otpCode          String?
  otpExpires       DateTime?
  isActive         Boolean   @default(true)
  balance          Decimal   @default(0)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lat              Float?    
  lng              Float?    

  orders           Order[]   @relation("MerchantOrders")
}

model Driver {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  name             String?
  password         String?
  googleId         String?  @unique
  facebookId       String?  @unique
  lineId           String?  @unique
  phone            String?  @unique
  fcmToken         String?
  
  vehiclePlate     String?  
  vehicleType      String?  

  isVerified       Boolean   @default(false)
  otpCode          String?
  otpExpires       DateTime?
  isActive         Boolean   @default(true)
  balance          Decimal   @default(0)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  orders           Order[]   @relation("DriverOrders")
}

model Order {
  id               Int           @id @default(autoincrement())
  trackingNumber   String        @unique
  productName      String
  productDetail    String?
  quantity         Int           @default(1)
  
  // --- ระบบราคาและสภาพอากาศ ---
  price            Decimal       // ราคาต้นทุนสินค้า
  totalPrice       Decimal?      // ราคาสุทธิที่ลูกค้ายต้องจ่าย (รวม Surge Price)
  weatherWarning   String?
  estimatedMinutes Int?          // ✅ ETA: ประมาณการเวลาจัดส่ง (นาที)
  hasInsurance     Boolean       @default(false) // ✅ Insurance toggle
  insuranceFee     Decimal       @default(0)     // ค่าธรรมเนียมประกัน
  
  receiverName     String
  receiverPhone    String
  address          String
  lat              Float?        // ✅ เพิ่ม: พิกัดละติจูดปลายทาง
  lng              Float?        // ✅ เพิ่ม: พิกัดลองจิจูดปลายทาง
  
  status           OrderStatus   @default(PENDING)
  paymentStatus    PaymentStatus @default(Unpaid)
  estimatedReadyAt DateTime?     

  paymentMethod    String?       
  proofOfDelivery  String?       

  customerId       Int?
  merchantId       Int?
  driverId         Int?

  customer         Customer?     @relation("CustomerOrders", fields: [customerId], references: [id])
  merchant         Merchant?     @relation("MerchantOrders", fields: [merchantId], references: [id])
  driver           Driver?       @relation("DriverOrders", fields: [driverId], references: [id])

  trackingLogs     TrackingLog[]
  messages         Message[]     
  transactions     Transaction[]
  rating           Rating?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model TrackingLog {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  status    String
  location  String?
  lat       Float?   
  lng       Float?   
  note      String?
  isPublic  Boolean  @default(true) // ✅ เพิ่ม: กำหนดว่าลูกค้าเห็น Log นี้ได้ไหม
  
  imageUrl  String?  

  createdAt DateTime @default(now())
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  
  orderId    Int?
  order      Order?   @relation(fields: [orderId], references: [id])

  senderRole String
  senderId   Int
  receiverRole String
  receiverId Int
  
  createdAt  DateTime @default(now())
  imageUrl   String?  
}

model Transaction {
  id        Int      @id @default(autoincrement())
  amount    Decimal
  type      String   // "DEBIT", "CREDIT"
  note      String?  // e.g. "Payment for Order #123"
  referenceId String? @unique // Stripe payment intent ID
  
  userId    Int
  userRole  String   // "Customer", "Merchant", "Driver"
  
  orderId   Int?
  order     Order?   @relation(fields: [orderId], references: [id])
  
  createdAt DateTime @default(now())
}

model Rating {
  id          Int      @id @default(autoincrement())
  score       Int      // 1-5
  comment     String?
  
  orderId     Int      @unique
  order       Order    @relation(fields: [orderId], references: [id])
  
  raterId     Int
  raterRole   String   // "Customer" or "Merchant"
  
  driverId    Int?     // Target of rating
  
  createdAt   DateTime @default(now())
}