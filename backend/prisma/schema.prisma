generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  Merchant
  Driver
  Customer
}

enum OrderStatus {
  PENDING
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  Unpaid
  Paid
}

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  name             String?
  password         String?
  googleId         String?  @unique
  phone            String?  @unique
  role             Role     @default(Customer)
  
  // --- ข้อมูลเพิ่มเติมตาม Role ---
  storeName        String?  // สำหรับ Merchant
  storeAddress     String?  // สำหรับ Merchant
  vehiclePlate     String?  // สำหรับ Driver
  vehicleType      String?  // สำหรับ Driver (เช่น มอเตอร์ไซค์, รถยนต์)

  // --- ระบบยืนยันอีเมล ---
  isVerified       Boolean   @default(false)
  otpCode          String?
  otpExpires       DateTime?

  // --- ระบบ Admin จัดการบัญชี ---
  isActive         Boolean   @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ordersAsCustomer Order[]   @relation("CustomerOrders")
  ordersAsMerchant Order[]   @relation("MerchantOrders")
  ordersAsDriver   Order[]   @relation("DriverOrders")
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Order {
  id               Int           @id @default(autoincrement())
  trackingNumber   String        @unique
  productName      String
  productDetail    String?
  quantity         Int           @default(1)
  
  // --- ระบบราคาและสภาพอากาศ ---
  price            Float         // ราคาต้นทุนสินค้า
  totalPrice       Float?        // ✅ เพิ่ม: ราคาสุทธิที่ลูกค้ายต้องจ่าย (รวม Surge Price)
  weatherWarning   String?
  
  receiverName     String
  receiverPhone    String
  address          String
  lat              Float?        // ✅ เพิ่ม: พิกัดละติจูดปลายทาง
  lng              Float?        // ✅ เพิ่ม: พิกัดลองจิจูดปลายทาง
  
  status           OrderStatus   @default(PENDING)
  paymentStatus    PaymentStatus @default(Unpaid)
  estimatedReadyAt DateTime?     

  paymentMethod    String?       
  proofOfDelivery  String?       

  customerId       Int?
  merchantId       Int
  driverId         Int?

  customer         User?         @relation("CustomerOrders", fields: [customerId], references: [id])
  merchant         User          @relation("MerchantOrders", fields: [merchantId], references: [id])
  driver           User?         @relation("DriverOrders", fields: [driverId], references: [id])

  trackingLogs     TrackingLog[]
  messages         Message[]     

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model TrackingLog {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  status    String
  location  String?
  lat       Float?   
  lng       Float?   
  note      String?
  isPublic  Boolean  @default(true) // ✅ เพิ่ม: กำหนดว่าลูกค้าเห็น Log นี้ได้ไหม
  
  imageUrl  String?  

  createdAt DateTime @default(now())
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  
  orderId    Int?
  order      Order?   @relation(fields: [orderId], references: [id])

  senderId   Int
  receiverId Int
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  
  createdAt  DateTime @default(now())
}